# Optional MCPs for task intake and PR review.
# Merge into ~/.codex/config.toml only for the providers you use.
# Credentials must stay in the target repository credential_mcp.env file.
# Do not commit credential_mcp.env.

[mcp_servers.atlassian-task-intake]
url = "https://mcp.atlassian.com/v1/mcp/authv2"

[mcp_servers.atlassian-bitbucket-pr-review]
url = "https://mcp.atlassian.com/v1/mcp/authv2"

[mcp_servers.gitlab-pr-review]
url = "https://gitlab.com/api/v4/mcp"

[mcp_servers.gitlab-pr-review.headers]
X-Gitlab-Mcp-Server-Tool-Name-Prefix = "gitlab_"

[mcp_servers.azure-devops-task-intake]
command = "zsh"
args = ["-lc", "cred=\"${MCP_CREDENTIAL_FILE:-$PWD/credential_mcp.env}\"; org=\"${AZURE_DEVOPS_ORG:-}\"; if [ -f \"$cred\" ]; then org=\"$(awk -F= '/^AZURE_DEVOPS_ORG=/{print substr($0,index($0,\"=\")+1)}' \"$cred\")\"; fi; test -n \"$org\" && npx -y @azure-devops/mcp \"$org\" -d core work work-items"]

[mcp_servers.azure-devops-pr-review]
command = "zsh"
args = ["-lc", "cred=\"${MCP_CREDENTIAL_FILE:-$PWD/credential_mcp.env}\"; org=\"${AZURE_DEVOPS_ORG:-}\"; if [ -f \"$cred\" ]; then org=\"$(awk -F= '/^AZURE_DEVOPS_ORG=/{print substr($0,index($0,\"=\")+1)}' \"$cred\")\"; fi; test -n \"$org\" && npx -y @azure-devops/mcp \"$org\" -d core repositories pipelines"]
