{
  "mcpServers": {
    "atlassian-task-intake": {
      "url": "https://mcp.atlassian.com/v1/mcp/authv2"
    },
    "azure-devops-task-intake": {
      "command": "zsh",
      "args": [
        "-lc",
        "test -n \"$AZURE_DEVOPS_ORG\" && npx -y @azure-devops/mcp \"$AZURE_DEVOPS_ORG\" -d core work work-items"
      ]
    }
  }
}
