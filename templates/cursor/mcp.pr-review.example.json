{
  "mcpServers": {
    "github-pr-review": {
      "command": "docker",
      "args": ["mcp", "gateway", "run", "--servers", "github-official"]
    },
    "gitlab-pr-review": {
      "url": "https://gitlab.com/api/v4/mcp",
      "headers": {
        "X-Gitlab-Mcp-Server-Tool-Name-Prefix": "gitlab_"
      }
    },
    "bitbucket-pr-review": {
      "url": "https://mcp.atlassian.com/v1/mcp/authv2"
    },
    "azure-devops-pr-review": {
      "command": "zsh",
      "args": [
        "-lc",
        "test -n \"$AZURE_DEVOPS_ORG\" && npx -y @azure-devops/mcp \"$AZURE_DEVOPS_ORG\" -d core repositories pipelines"
      ]
    }
  }
}
